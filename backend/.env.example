# === Klucze API ===

# OpenWeatherMap – prognoza pogody
# Zarejestruj się: https://openweathermap.org/api
OWM_API_KEY=twoj_klucz_openweathermap

# Airly – jakość powietrza (dokładniejsze dane niż GIOŚ)
# Zarejestruj się: https://developer.airly.org/
AIRLY_API_KEY=twoj_klucz_airly

# === Uwagi ===
# 1. Skopiuj ten plik jako .env i uzupełnij klucze.
# 2. Plik .env jest ignorowany przez git – NIGDY nie wrzucaj go do repozytorium.
# 3. backend/.env jest automatycznie ładowany przez dotenv przy starcie serwera.
